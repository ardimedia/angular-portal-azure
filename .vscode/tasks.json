{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:lib",
      "type": "npm",
      "script": "build:lib",
      "path": "angular-portal-azure",
      "problemMatcher": "$tsc"
    },
    {
      "label": "watch:lib",
      "type": "npm",
      "script": "watch:lib",
      "path": "angular-portal-azure",
      "isBackground": true,
      "problemMatcher": {
        "owner": "ng-lib",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": { "regexp": "Building entry point" },
          "endsPattern": { "regexp": "Built @ardimedia" }
        }
      }
    },
    {
      "label": "serve",
      "type": "npm",
      "script": "start",
      "path": "angular-portal-azure",
      "isBackground": true,
      "dependsOn": "build:lib",
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": { "regexp": "Changes detected|Building\\.\\.\\." },
          "endsPattern": { "regexp": "bundle generation (complete|failed)" }
        }
      }
    },
    {
      "label": "dev",
      "dependsOn": ["watch:lib", "serve"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "type": "npm",
      "script": "test",
      "path": "angular-portal-azure",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": { "regexp": "Changes detected" },
          "endsPattern": { "regexp": "bundle generation (complete|failed)" }
        }
      }
    }
  ]
}
